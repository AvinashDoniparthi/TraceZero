# TraceZero — Environment Variables
# Copy this file to .env and fill in your keys.
# The app works in simulation mode without any keys (except Gemini for real AI).
# Set these as Environment Variables in your Render dashboard — DO NOT commit real keys.

# ─── Have I Been Pwned ─────────────────────────────────────────────────────────
# Breach lookup for emails.
# Sign up: https://haveibeenpwned.com/API/Key
# Cost: ~$3.50/month (no free tier — app simulates data without this key)
HIBP_API_KEY=

# ─── Hunter.io ─────────────────────────────────────────────────────────────────
# Email verification + domain intelligence.
# Sign up FREE: https://hunter.io  (25 free requests/month, no credit card)
# Skip this → /scan returns "skipped" for email_intel section
HUNTER_API_KEY=

# ─── VirusTotal ────────────────────────────────────────────────────────────────
# Domain/URL security scanning — 90+ antivirus engines.
# Sign up FREE: https://www.virustotal.com/gui/join-us  (500 req/day, 4 req/min)
# Skip this → /scan returns "skipped" for domain_security section
VIRUSTOTAL_API_KEY=

# ─── Social Searcher ───────────────────────────────────────────────────────────
# Social media & web mention search.
# Sign up FREE: https://www.social-searcher.com/api/  (100 req/day without key)
# The app calls without a key by default (100 free daily req).
# Add key here if you want higher limits.
SOCIAL_SEARCHER_API_KEY=

# ─── LeakCheck ─────────────────────────────────────────────────────────────────
# Credential leak lookup — completely FREE, NO API key required.
# Works for both email and username. Rate limit: 1 req/second.
# Docs: https://wiki.leakcheck.io/en/api/public
# Attribution: include "Powered by LeakCheck" if used on a public website.
# (No variable needed — enabled automatically)

# ─── Google Gemini (AI Chatbot) ────────────────────────────────────────────────
# Powers the /chat endpoint with Gemini 2.0 Flash.
# Get FREE key: https://aistudio.google.com/apikey  (1,500 req/day, no cost)
# Without this → chatbot returns curated simulated responses.
GEMINI_API_KEY=
